---
import { getCollection } from 'astro:content';
import { readdirSync } from 'node:fs';
import { join } from 'node:path';
import LearningModuleCard from '../../components/learn/LearningModuleCard.astro';
import ProgressSummary from '../../components/learn/ProgressSummary.astro';
import { MODULES } from '../../content/knowledge/modules';
import graphAnalysisData from '../../data/graph-analysis.json';
import graphData from '../../data/knowledge-graph.json';
import LearnLayout from '../../layouts/LearnLayout.astro';
import type { GraphAnalysis } from '../../utils/graph-analysis';
import { prepareGraphAnalysisDisplay } from '../../utils/graph-analysis';
import { computeGraphStats } from '../../utils/graph-stats';

export const prerender = true;

// TODO: Future search feature should index article altLabels alongside titles.
// The SKOS altLabels field was designed to power synonym-aware search
// (e.g., searching "IoC" should find "Inversion of Control").
// When adding Pagefind or Fuse.js, configure it to search across
// title + altLabels + summary.

const stats = computeGraphStats(graphData);
const graphAnalysis = prepareGraphAnalysisDisplay(graphAnalysisData as GraphAnalysis);
const articleLabelById = new Map<string, string>(
  graphData.nodes.filter((node) => node.type === 'article').map((node) => [node.id, node.label]),
);
const getArticleLabel = (id: string): string => articleLabelById.get(id) ?? id;
const topCentrality = graphAnalysis.centrality.slice(0, 5);
const topCommunities = graphAnalysis.communities.slice(0, 4);

// Count flagged articles
let flaggedCount = 0;
try {
  const flagDir = join(process.cwd(), 'src/data/review-flags');
  const files = readdirSync(flagDir).filter((f) => f.endsWith('.json'));
  flaggedCount = files.length;
} catch {
  // Directory doesn't exist or can't be read — 0 flags
}

interface KnowledgeEntry {
  id: string;
  data: {
    title: string;
    category: string;
    summary: string;
    difficulty?: string;
    order?: number;
    module?: string;
    moduleOrder?: number;
    estimatedMinutes?: number;
    prerequisites: string[];
  };
}

const entries = (await getCollection('knowledge')) as KnowledgeEntry[];

// Group by category (for browse section)
const categories: Record<string, KnowledgeEntry[]> = {};
for (const entry of entries) {
  const cat = entry.data.category;
  if (!categories[cat]) categories[cat] = [];
  categories[cat].push(entry);
}
for (const cat of Object.keys(categories)) {
  categories[cat]?.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
}

const categoryOrder = [
  'architecture',
  'concept',
  'technology',
  'feature',
  'cs-fundamentals',
  'lab',
];
const categoryLabels: Record<string, string> = {
  architecture: '🏗️ Architecture',
  concept: '💡 Concepts',
  technology: '🔧 Technologies',
  feature: '✨ Features',
  'cs-fundamentals': '🧠 CS Fundamentals',
  lab: '🧪 Labs',
};

// Group articles by module
const moduleArticles: Record<string, KnowledgeEntry[]> = {};
for (const entry of entries) {
  const moduleId = entry.data.module;
  if (moduleId) {
    moduleArticles[moduleId] ??= [];
    moduleArticles[moduleId].push(entry);
  }
}
for (const mod of Object.keys(moduleArticles)) {
  moduleArticles[mod]?.sort((a, b) => (a.data.moduleOrder ?? 99) - (b.data.moduleOrder ?? 99));
}

// Labs for dedicated section
const labs = entries
  .filter((e) => e.data.category === 'lab')
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

// Sort modules by order
const sortedModules = [...MODULES].sort((a, b) => a.order - b.order);
---

<LearnLayout title="Knowledge Base">
  <div class="learn-page">
    <aside class="learn-sidebar">
      <h3>Learning Path</h3>
      <ul>
        {sortedModules.map((mod) => (
          <li><a href={`#module-${mod.id}`}>{mod.title}</a></li>
        ))}
      </ul>
      <h3>Categories</h3>
      <ul>
        {categoryOrder.map((cat) => (
          <li><a href={`#${cat}`}>{categoryLabels[cat]}</a></li>
        ))}
      </ul>
    </aside>

    <main class="learn-content">
      <h1>Knowledge Base</h1>
      <p class="learn-content__summary">
        A structured learning system for understanding this platform — the architecture, technologies, patterns, CS fundamentals, and hands-on experiments.
      </p>

      <ProgressSummary />

      {/* ===== Graph Stats Dashboard ===== */}
      <details class="graph-stats">
        <summary class="graph-stats__toggle">📈 Knowledge Graph Stats</summary>
        <div class="graph-stats__content">
          {/* Row 1: Overview counts */}
          <div class="graph-stats__grid">
            <div class="graph-stats__card">
              <span class="graph-stats__number">{stats.nodes.byType['article'] ?? 0}</span>
              <span class="graph-stats__label">Articles</span>
            </div>
            <div class="graph-stats__card">
              <span class="graph-stats__number">{stats.edges.total}</span>
              <span class="graph-stats__label">Edges</span>
            </div>
            <div class="graph-stats__card">
              <span class="graph-stats__number">{stats.longestPrerequisiteChain}</span>
              <span class="graph-stats__label">Longest prereq chain</span>
            </div>
            <div class="graph-stats__card">
              <span class="graph-stats__number">{stats.orphanArticles.length}</span>
              <span class="graph-stats__label">Orphan articles</span>
            </div>
            <div class="graph-stats__card">
              <span class="graph-stats__number">{flaggedCount}</span>
              <span class="graph-stats__label">Flagged for review</span>
            </div>
          </div>

          {/* Row 2: Nodes & edges by type */}
          <div class="graph-stats__tables">
            <div>
              <h4 class="graph-stats__heading">Nodes by Type</h4>
              <table class="graph-stats__table">
                <thead><tr><th>Type</th><th>Count</th></tr></thead>
                <tbody>
                  {Object.entries(stats.nodes.byType)
                    .sort(([, a], [, b]) => b - a)
                    .map(([type, count]) => (
                      <tr><td>{type}</td><td>{count}</td></tr>
                    ))}
                  <tr class="graph-stats__total"><td>Total</td><td>{stats.nodes.total}</td></tr>
                </tbody>
              </table>
            </div>
            <div>
              <h4 class="graph-stats__heading">Edges by Type</h4>
              <table class="graph-stats__table">
                <thead><tr><th>Type</th><th>Count</th></tr></thead>
                <tbody>
                  {Object.entries(stats.edges.byType)
                    .sort(([, a], [, b]) => b - a)
                    .map(([type, count]) => (
                      <tr><td>{type}</td><td>{count}</td></tr>
                    ))}
                  <tr class="graph-stats__total"><td>Total</td><td>{stats.edges.total}</td></tr>
                </tbody>
              </table>
            </div>
          </div>

          {/* Row 3: Articles per category */}
          <h4 class="graph-stats__heading">Articles per Category</h4>
          <table class="graph-stats__table">
            <thead><tr><th>Category</th><th>Count</th></tr></thead>
            <tbody>
              {stats.articlesPerCategory.map(({ category, count }) => (
                <tr><td>{category}</td><td>{count}</td></tr>
              ))}
            </tbody>
          </table>

          {/* Row 4: Module sizes */}
          <h4 class="graph-stats__heading">Articles per Module</h4>
          <table class="graph-stats__table">
            <thead><tr><th>Module</th><th>Articles</th></tr></thead>
            <tbody>
              {stats.moduleSizes.map(({ label, count }) => (
                <tr><td>{label}</td><td>{count}</td></tr>
              ))}
            </tbody>
          </table>

          {/* Row 5: Longest prerequisite chain */}
          {stats.prerequisiteChainPath.length > 1 && (
            <div>
              <h4 class="graph-stats__heading">Longest Prerequisite Chain ({stats.longestPrerequisiteChain} steps)</h4>
              <ol class="graph-stats__chain">
                {stats.prerequisiteChainPath.map((id) => (
                  <li><a href={`/learn/${id}`}>{getArticleLabel(id)}</a></li>
                ))}
              </ol>
            </div>
          )}

          {/* Row 6: NetworkX analysis */}
          <div data-cy="graph-analysis">
            <h4 class="graph-stats__heading">Network Analysis</h4>
            <div class="graph-stats__grid">
              <div class="graph-stats__card">
                <span class="graph-stats__number">{graphAnalysis.communities.length}</span>
                <span class="graph-stats__label">Communities</span>
              </div>
              <div class="graph-stats__card">
                <span class="graph-stats__number">{graphAnalysis.summary.weaklyConnectedComponents}</span>
                <span class="graph-stats__label">Full-graph components</span>
              </div>
              <div class="graph-stats__card">
                <span class="graph-stats__number">{graphAnalysis.coverageGaps.disconnectedComponents.length}</span>
                <span class="graph-stats__label">Disconnected semantic clusters</span>
              </div>
              <div class="graph-stats__card">
                <span class="graph-stats__number">{graphAnalysis.coverageGaps.highTrafficLowContent.length}</span>
                <span class="graph-stats__label">Priority content upgrades</span>
              </div>
            </div>

            <div class="graph-stats__tables">
              <div>
                <h4 class="graph-stats__heading">Top Central Concepts (PageRank)</h4>
                <table class="graph-stats__table" data-cy="graph-analysis-centrality">
                  <thead><tr><th>#</th><th>Concept</th><th>Score</th></tr></thead>
                  <tbody>
                    {topCentrality.map((entry, index) => (
                      <tr>
                        <td>{index + 1}</td>
                        <td><a href={`/learn/${entry.id}`}>{entry.label}</a></td>
                        <td>{entry.score.toFixed(4)}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
              <div>
                <h4 class="graph-stats__heading">Prerequisite Depth Distribution</h4>
                <table class="graph-stats__table">
                  <thead><tr><th>Depth</th><th>Articles</th></tr></thead>
                  <tbody>
                    {graphAnalysis.depthDistribution.map(({ depth, count }) => (
                      <tr><td>{depth}</td><td>{count}</td></tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>

            {graphAnalysis.prerequisiteDepth.longestPath.length > 0 && (
              <div>
                <h4 class="graph-stats__heading">Critical Learning Path ({graphAnalysis.prerequisiteDepth.maxDepth} articles)</h4>
                <p class="graph-stats__note">Learning-order view from foundational prerequisite to the most dependent article.</p>
                <ol class="graph-stats__chain">
                  {graphAnalysis.prerequisiteDepth.longestPath.map((id) => (
                    <li><a href={`/learn/${id}`}>{getArticleLabel(id)}</a></li>
                  ))}
                </ol>
              </div>
            )}

            {topCommunities.length > 0 && (
              <div>
                <h4 class="graph-stats__heading">Detected Communities</h4>
                <table class="graph-stats__table">
                  <thead><tr><th>Label</th><th>Size</th><th>Sample members</th></tr></thead>
                  <tbody>
                    {topCommunities.map((community) => (
                      <tr>
                        <td>{community.suggestedLabel}</td>
                        <td>{community.size}</td>
                        <td>
                          {community.members.slice(0, 3).map((memberId, memberIndex) => (
                            <span>
                              {memberIndex > 0 && ', '}
                              <a href={`/learn/${memberId}`}>{getArticleLabel(memberId)}</a>
                            </span>
                          ))}
                          {community.size > 3 && ` +${community.size - 3} more`}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}

            {graphAnalysis.coverageGaps.highTrafficLowContent.length > 0 && (
              <div>
                <h4 class="graph-stats__heading">High-Traffic, Low-Content Articles</h4>
                <p class="graph-stats__note">Articles in the top quartile for incoming concept references that are still short for their category.</p>
                <table class="graph-stats__table">
                  <thead><tr><th>Article</th><th>Incoming refs</th><th>Words</th><th>Why it needs work</th></tr></thead>
                  <tbody>
                    {graphAnalysis.coverageGaps.highTrafficLowContent.map((entry) => (
                      <tr>
                        <td><a href={`/learn/${entry.id}`}>{entry.label}</a></td>
                        <td>{entry.incomingReferences}</td>
                        <td>{entry.wordCount ?? '—'}</td>
                        <td>{entry.reasons.join('; ')}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}

            {graphAnalysis.coverageGaps.uncoveredTechnologies.length > 0 && (
              <div>
                <h4 class="graph-stats__heading">Uncovered Technologies</h4>
                <ul class="graph-stats__list">
                  {graphAnalysis.coverageGaps.uncoveredTechnologies.map((technology) => (
                    <li>{technology}</li>
                  ))}
                </ul>
              </div>
            )}

            {graphAnalysis.coverageGaps.deadEndArticles.length > 0 && (
              <div>
                <h4 class="graph-stats__heading">Dead-End Articles</h4>
                <ul class="graph-stats__list">
                  {graphAnalysis.coverageGaps.deadEndArticles.map((id) => (
                    <li><a href={`/learn/${id}`}>{getArticleLabel(id)}</a></li>
                  ))}
                </ul>
              </div>
            )}

            {graphAnalysis.coverageGaps.disconnectedComponents.length > 0 && (
              <div>
                <h4 class="graph-stats__heading">Disconnected Semantic Clusters</h4>
                <p class="graph-stats__note">These article groups are disconnected from the main article graph and likely need cross-domain links.</p>
                <ul class="graph-stats__list">
                  {graphAnalysis.coverageGaps.disconnectedComponents.map((component) => (
                    <li>
                      {component.map((id, index) => (
                        <span>
                          {index > 0 && ', '}
                          <a href={`/learn/${id}`}>{getArticleLabel(id)}</a>
                        </span>
                      ))}
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>

          {/* Row 7: Technology gaps */}
          {stats.technologyGaps.length > 0 && (
            <div>
              <h4 class="graph-stats__heading">Technology Coverage Gaps</h4>
              <p class="graph-stats__note">Technologies referenced in articles but missing a dedicated technology article:</p>
              <ul class="graph-stats__list">
                {stats.technologyGaps.map(({ label }) => (
                  <li>{label}</li>
                ))}
              </ul>
            </div>
          )}

          {/* Row 8: Orphan articles */}
          {stats.orphanArticles.length > 0 && (
            <div>
              <h4 class="graph-stats__heading">Orphan Articles</h4>
              <p class="graph-stats__note">Articles not referenced by any other article's prerequisites or related concepts:</p>
              <ul class="graph-stats__list">
                {stats.orphanArticles.map(({ id }) => (
                  <li><a href={`/learn/${id}`}>{getArticleLabel(id)}</a></li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </details>

      {/* ===== Learning Path ===== */}
      <h2>🎓 Learning Path</h2>
      <p>Work through these modules in order. Each builds on the previous ones.</p>

      <div class="learn-modules">
        {sortedModules.map((mod) => {
          const articles = moduleArticles[mod.id] ?? [];
          const prereqNames = mod.prerequisites
            .map((pid) => MODULES.find((m) => m.id === pid)?.title)
            .filter((title): title is string => title !== undefined);

          return (
            <LearningModuleCard
              id={mod.id}
              title={mod.title}
              objective={mod.objective}
              prerequisiteLabels={prereqNames}
              articles={articles.map((article) => ({ id: article.id, title: article.data.title }))}
              articleSlugs={articles.map((article) => article.id)}
              estimatedHours={mod.estimatedHours}
            />
          );
        })}
      </div>

      {/* ===== Labs ===== */}
      {labs.length > 0 && (
        <>
          <h2 id="lab">🧪 Labs</h2>
          <p>Guided hands-on experiments in your own codebase.</p>
          <div class="learn-labs">
            {labs.map((lab) => (
              <div class="learn-lab-card">
                <a href={`/learn/${lab.id}`}>{lab.data.title}</a>
                {lab.data.estimatedMinutes && (
                  <span class="learn-lab-card__time">{lab.data.estimatedMinutes} min</span>
                )}
                {lab.data.difficulty && (
                  <span class={`learn-badge learn-badge--${lab.data.difficulty}`}>
                    {lab.data.difficulty}
                  </span>
                )}
              </div>
            ))}
          </div>
        </>
      )}

      {/* ===== Browse by Category ===== */}
      <h2>📚 Browse by Category</h2>
      {categoryOrder.map((cat) => {
        const items = categories[cat];
        if (!items?.length) return null;
        return (
          <>
            <h3 id={cat}>{categoryLabels[cat]}</h3>
            <ul>
              {items.map((entry) => (
                <li>
                  <a href={`/learn/${entry.id}`}>{entry.data.title}</a>
                  {entry.data.difficulty && (
                    <span class={`learn-badge learn-badge--${entry.data.difficulty}`}>
                      {entry.data.difficulty}
                    </span>
                  )}
                  <br />
                  <em>{entry.data.summary}</em>
                </li>
              ))}
            </ul>
          </>
        );
      })}
    </main>
  </div>
</LearnLayout>
