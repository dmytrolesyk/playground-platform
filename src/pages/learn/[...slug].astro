---
import { getCollection } from 'astro:content';
import LearnLayout from '../../layouts/LearnLayout.astro';

export const prerender = true;

interface KnowledgeEntry {
  id: string;
  data: {
    title: string;
    category: string;
    summary: string;
    difficulty?: string;
    relatedConcepts: string[];
    relatedFiles: string[];
    technologies: string[];
    externalReferences: Array<{ title: string; url: string; type: string }>;
    order?: number;
    // v2 fields
    prerequisites: string[];
    learningObjectives: string[];
    exercises: Array<{
      question: string;
      hint?: string;
      answer: string;
      type: string;
      fragments?: string[];
      correctOrder?: number[];
      approachA?: string;
      approachB?: string;
      steps?: Array<{ description: string; expectedState: string }>;
      targetConcepts?: string[];
    }>;
    estimatedMinutes?: number;
    module?: string;
    moduleOrder?: number;
    // SKOS fields
    altLabels: string[];
    broader: string[];
    narrower: string[];
    prefLabel?: string;
    conceptScheme: string;
    // Epistemic metadata
    confidence: 'established' | 'probable' | 'uncertain' | 'speculative';
    evidenceType?: 'authoritative' | 'derived' | 'empirical' | 'analogical';
    isContested: boolean;
  };
  rendered?: { html: string };
  body?: string;
}

export async function getStaticPaths() {
  const entries = await getCollection('knowledge');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: KnowledgeEntry };

const allEntries = (await getCollection('knowledge')) as KnowledgeEntry[];

// Build sidebar navigation grouped by category
const categories: Record<string, KnowledgeEntry[]> = {};
for (const e of allEntries) {
  const cat = e.data.category;
  if (!categories[cat]) {
    categories[cat] = [];
  }
  categories[cat].push(e);
}
for (const cat of Object.keys(categories)) {
  const items = categories[cat];
  if (items) {
    items.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
  }
}

const categoryOrder = [
  'architecture',
  'concept',
  'technology',
  'feature',
  'cs-fundamentals',
  'lab',
];
const categoryLabels: Record<string, string> = {
  architecture: 'Architecture',
  concept: 'Concepts',
  technology: 'Technologies',
  feature: 'Features',
  'cs-fundamentals': 'CS Fundamentals',
  lab: 'Labs',
};

const typeIcons: Record<string, string> = {
  article: '📄',
  video: '🎥',
  docs: '📚',
  talk: '🎤',
  repo: '💻',
  book: '📖',
};

// Resolve related concepts to actual entries
const relatedEntries = entry.data.relatedConcepts
  .map((slug: string) =>
    allEntries.find((e: KnowledgeEntry) => e.id === slug || e.id.endsWith(`/${slug}`)),
  )
  .filter((e): e is KnowledgeEntry => e !== undefined);

// Resolve prerequisites to actual entries
const prerequisiteEntries = (entry.data.prerequisites ?? [])
  .map((slug: string) =>
    allEntries.find((e: KnowledgeEntry) => e.id === slug || e.id.endsWith(`/${slug}`)),
  )
  .filter((e): e is KnowledgeEntry => e !== undefined);

// Find previous/next article in same module
const moduleArticles = entry.data.module
  ? allEntries
      .filter((e: KnowledgeEntry) => e.data.module === entry.data.module)
      .sort((a, b) => (a.data.moduleOrder ?? 99) - (b.data.moduleOrder ?? 99))
  : [];
const currentModuleIndex = moduleArticles.findIndex((e) => e.id === entry.id);
const prevInModule = currentModuleIndex > 0 ? moduleArticles[currentModuleIndex - 1] : null;
const nextInModule =
  currentModuleIndex < moduleArticles.length - 1 ? moduleArticles[currentModuleIndex + 1] : null;

const exerciseTypeLabels: Record<string, string> = {
  predict: '🔮 Predict',
  explain: '💬 Explain',
  do: '🛠️ Do',
  debug: '🐛 Debug',
  arrange: '🔢 Arrange',
  compare: '⚖️ Compare',
  trace: '🔍 Trace',
};

const html = entry.rendered?.html ?? entry.body ?? '';
const hasPracticeCheckpoint =
  entry.data.category === 'lab' || entry.data.exercises.some((exercise) => exercise.type === 'do');

// Resolve broader/narrower to actual entries
const broaderEntries = (entry.data.broader ?? [])
  .map((slug: string) =>
    allEntries.find((e: KnowledgeEntry) => e.id === slug || e.id.endsWith(`/${slug}`)),
  )
  .filter((e): e is KnowledgeEntry => e !== undefined);

const narrowerEntries = (entry.data.narrower ?? [])
  .map((slug: string) =>
    allEntries.find((e: KnowledgeEntry) => e.id === slug || e.id.endsWith(`/${slug}`)),
  )
  .filter((e): e is KnowledgeEntry => e !== undefined);

// Epistemic metadata
const confidence = entry.data.confidence ?? 'established';
const isContested = entry.data.isContested ?? false;
const showEpistemicBanner = confidence !== 'established' || isContested;

const confidenceMessages: Record<string, string> = {
  probable: '⚠️ This content is based on good evidence but is not definitive.',
  uncertain: '⚠️ This content has limited supporting evidence.',
  speculative: '⚠️ This content is speculative — inferred but not verified.',
};
---

<LearnLayout title={entry.data.title}>
  <div class="learn-page">
    <aside class="learn-sidebar">
      {categoryOrder.map((cat) => {
        const items = categories[cat];
        if (!items?.length) return null;
        return (
          <>
            <h3>{categoryLabels[cat]}</h3>
            <ul>
              {items.map((e: KnowledgeEntry) => (
                <li>
                  <a
                    href={`/learn/${e.id}`}
                    class={e.id === entry.id ? 'active' : ''}
                  >
                    {e.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </>
        );
      })}
    </aside>

    <main class="learn-content">
      <h1>{entry.data.title}</h1>
      {entry.data.difficulty && (
        <span class={`learn-badge learn-badge--${entry.data.difficulty}`}>
          {entry.data.difficulty}
        </span>
      )}
      <p class="learn-content__summary">{entry.data.summary}</p>

      {/* Estimated reading time */}
      {entry.data.estimatedMinutes && (
        <p class="learn-meta__time">⏱️ Estimated: {entry.data.estimatedMinutes} minutes</p>
      )}

      {/* Epistemic metadata banner */}
      {showEpistemicBanner && (
        <div class={`learn-epistemic learn-epistemic--${confidence}`}>
          {isContested && (
            <p class="learn-epistemic__contested">
              ⚖️ This is a contested topic — multiple valid perspectives exist.
            </p>
          )}
          {confidence !== 'established' && confidenceMessages[confidence] && (
            <p class="learn-epistemic__confidence">{confidenceMessages[confidence]}</p>
          )}
        </div>
      )}

      {/* Prerequisites */}
      {prerequisiteEntries.length > 0 && (
        <div class="learn-prerequisites">
          <strong>📋 Read first:</strong>
          <ul>
            {prerequisiteEntries.map((e: KnowledgeEntry) => (
              <li><a href={`/learn/${e.id}`}>{e.data.title}</a></li>
            ))}
          </ul>
        </div>
      )}

      {/* Learning objectives */}
      {entry.data.learningObjectives.length > 0 && (
        <div class="learn-objectives">
          <strong>🎯 After reading this, you should be able to:</strong>
          <ul>
            {entry.data.learningObjectives.map((obj: string) => (
              <li>{obj}</li>
            ))}
          </ul>
        </div>
      )}

      <article set:html={html} />

      {/* Progress tracking placeholder — hydrated by client script */}
      <div
        id="progress-tracker"
        data-slug={entry.id}
        data-has-practice-checkpoint={hasPracticeCheckpoint ? 'true' : 'false'}
      ></div>

      {/* Flag for review */}
      <div id="flag-for-review" data-article-id={entry.id} class="flag-review">
        <button type="button" class="flag-review__btn" id="flag-review-btn">
          🚩 Flag for Review
        </button>
        <span class="flag-review__status" id="flag-review-status"></span>
      </div>

      {/* Exercises */}
      {entry.data.exercises.length > 0 && (
        <section class="learn-exercises">
          <h2>🧪 Check Your Understanding</h2>
          {entry.data.exercises.map((ex) => (
            <div class={`exercise exercise--${ex.type}`}>
              <p class="exercise__label">{exerciseTypeLabels[ex.type] ?? ex.type}</p>
              <p class="exercise__question">{ex.question}</p>

              {/* arrange: show fragments as numbered list */}
              {ex.type === 'arrange' && ex.fragments && (
                <ol class="exercise__fragments">
                  {ex.fragments.map((fragment: string) => (
                    <li>{fragment}</li>
                  ))}
                </ol>
              )}

              {/* compare: show approaches side-by-side */}
              {ex.type === 'compare' && (ex.approachA || ex.approachB) && (
                <div class="exercise__approaches">
                  {ex.approachA && (
                    <div class="exercise__approach">
                      <p class="exercise__approach-label">Approach A</p>
                      <pre>{ex.approachA}</pre>
                    </div>
                  )}
                  {ex.approachB && (
                    <div class="exercise__approach">
                      <p class="exercise__approach-label">Approach B</p>
                      <pre>{ex.approachB}</pre>
                    </div>
                  )}
                </div>
              )}

              {/* trace: show steps with expected state */}
              {ex.type === 'trace' && ex.steps && (
                <ol class="exercise__steps">
                  {ex.steps.map((step: { description: string; expectedState: string }) => (
                    <li>
                      <p class="exercise__step-description">{step.description}</p>
                      <p class="exercise__step-state">→ {step.expectedState}</p>
                    </li>
                  ))}
                </ol>
              )}

              {ex.hint && (
                <details class="exercise__hint">
                  <summary>Show hint</summary>
                  <p>{ex.hint}</p>
                </details>
              )}
              <details class="exercise__answer">
                <summary>Show answer</summary>
                <p>{ex.answer}</p>
              </details>
            </div>
          ))}
        </section>
      )}

      <section class="learn-related">
        {broaderEntries.length > 0 && (
          <>
            <h2>🔼 Broader Concepts</h2>
            <ul>
              {broaderEntries.map((e: KnowledgeEntry) => (
                <li><a href={`/learn/${e.id}`}>{e.data.title}</a> — {e.data.summary}</li>
              ))}
            </ul>
          </>
        )}

        {narrowerEntries.length > 0 && (
          <>
            <h2>🔽 Narrower Concepts</h2>
            <ul>
              {narrowerEntries.map((e: KnowledgeEntry) => (
                <li><a href={`/learn/${e.id}`}>{e.data.title}</a> — {e.data.summary}</li>
              ))}
            </ul>
          </>
        )}

        {relatedEntries.length > 0 && (
          <>
            <h2>📎 Related Concepts</h2>
            <ul>
              {relatedEntries.map((e: KnowledgeEntry) => (
                <li><a href={`/learn/${e.id}`}>{e.data.title}</a> — {e.data.summary}</li>
              ))}
            </ul>
          </>
        )}

        {entry.data.relatedFiles.length > 0 && (
          <>
            <h2>📁 Source Files</h2>
            <ul>
              {entry.data.relatedFiles.map((f: string) => (
                <li><code>{f}</code></li>
              ))}
            </ul>
          </>
        )}

        {entry.data.externalReferences.length > 0 && (
          <div class="learn-external">
            <h2>🔗 External References</h2>
            {entry.data.externalReferences.map((ref: { title: string; url: string; type: string }) => (
              <div class="learn-external__item">
                <span class="learn-external__type">{typeIcons[ref.type] ?? '📄'} {ref.type}</span>
                <a href={ref.url} target="_blank" rel="noopener noreferrer">{ref.title}</a>
              </div>
            ))}
          </div>
        )}
      </section>

      {/* Module navigation */}
      {(prevInModule || nextInModule) && (
        <nav class="learn-module-nav">
          {prevInModule ? (
            <a href={`/learn/${prevInModule.id}`} class="learn-module-nav__prev">
              ← {prevInModule.data.title}
            </a>
          ) : <span />}
          {nextInModule ? (
            <a href={`/learn/${nextInModule.id}`} class="learn-module-nav__next">
              {nextInModule.data.title} →
            </a>
          ) : <span />}
        </nav>
      )}
    </main>
  </div>
</LearnLayout>
