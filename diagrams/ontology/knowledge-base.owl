<?xml version="1.0"?>
<rdf:RDF xmlns="http://playground-platform.dev/ontology/knowledge-base#"
     xml:base="http://playground-platform.dev/ontology/knowledge-base"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:kb="http://playground-platform.dev/ontology/knowledge-base#">

    <owl:Ontology rdf:about="http://playground-platform.dev/ontology/knowledge-base">
        <rdfs:label>Playground Platform Knowledge Base Ontology</rdfs:label>
        <rdfs:comment>A small OWL ontology modelling the playground-platform knowledge base.
Built as a learning exercise for the OWL lab (Feature 11).</rdfs:comment>
        <owl:versionInfo>0.1.0</owl:versionInfo>
    </owl:Ontology>

    <!-- ============================================================ -->
    <!-- Classes                                                       -->
    <!-- ============================================================ -->

    <owl:Class rdf:about="#KnowledgeArticle">
        <rdfs:label>Knowledge Article</rdfs:label>
        <rdfs:comment>Any article in the knowledge base, regardless of category.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#Concept">
        <rdfs:subClassOf rdf:resource="#KnowledgeArticle"/>
        <rdfs:label>Concept</rdfs:label>
        <rdfs:comment>An article explaining a conceptual idea (e.g., Observer Pattern, Islands Architecture).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#Technology">
        <rdfs:subClassOf rdf:resource="#KnowledgeArticle"/>
        <rdfs:label>Technology</rdfs:label>
        <rdfs:comment>An article covering a specific tool or framework (e.g., SolidJS, Astro).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#Architecture">
        <rdfs:subClassOf rdf:resource="#KnowledgeArticle"/>
        <rdfs:label>Architecture</rdfs:label>
        <rdfs:comment>An article describing a structural aspect of the codebase.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#Lab">
        <rdfs:subClassOf rdf:resource="#KnowledgeArticle"/>
        <rdfs:label>Lab</rdfs:label>
        <rdfs:comment>A hands-on exercise following DO → OBSERVE → EXPLAIN structure.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#CSFundamentals">
        <rdfs:subClassOf rdf:resource="#KnowledgeArticle"/>
        <rdfs:label>CS Fundamentals</rdfs:label>
        <rdfs:comment>An article covering foundational computer science concepts.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#Feature">
        <rdfs:subClassOf rdf:resource="#KnowledgeArticle"/>
        <rdfs:label>Feature</rdfs:label>
        <rdfs:comment>An article documenting a specific feature of the platform.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#CurriculumModule">
        <rdfs:label>Curriculum Module</rdfs:label>
        <rdfs:comment>A group of related articles forming a learning unit.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="#Difficulty">
        <rdfs:label>Difficulty</rdfs:label>
        <rdfs:comment>The difficulty level of an article.</rdfs:comment>
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="#Beginner"/>
                    <rdf:Description rdf:about="#Intermediate"/>
                    <rdf:Description rdf:about="#Advanced"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>

    <!-- ============================================================ -->
    <!-- Disjointness: category subclasses don't overlap               -->
    <!-- ============================================================ -->

    <rdf:Description>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <rdf:Description rdf:about="#Concept"/>
            <rdf:Description rdf:about="#Technology"/>
            <rdf:Description rdf:about="#Architecture"/>
            <rdf:Description rdf:about="#Lab"/>
            <rdf:Description rdf:about="#CSFundamentals"/>
            <rdf:Description rdf:about="#Feature"/>
        </owl:members>
    </rdf:Description>

    <!-- ============================================================ -->
    <!-- Object Properties                                             -->
    <!-- ============================================================ -->

    <owl:ObjectProperty rdf:about="#hasPrerequisite">
        <rdfs:label>has prerequisite</rdfs:label>
        <rdfs:comment>Article A hasPrerequisite B means B must be read before A.</rdfs:comment>
        <rdfs:domain rdf:resource="#KnowledgeArticle"/>
        <rdfs:range rdf:resource="#KnowledgeArticle"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#relatedTo">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:label>related to</rdfs:label>
        <rdfs:comment>A symmetric associative link between two articles.</rdfs:comment>
        <rdfs:domain rdf:resource="#KnowledgeArticle"/>
        <rdfs:range rdf:resource="#KnowledgeArticle"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#belongsToModule">
        <rdfs:label>belongs to module</rdfs:label>
        <rdfs:comment>Assigns an article to a curriculum module.</rdfs:comment>
        <rdfs:domain rdf:resource="#KnowledgeArticle"/>
        <rdfs:range rdf:resource="#CurriculumModule"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#moduleRequires">
        <rdfs:label>module requires</rdfs:label>
        <rdfs:comment>Module A moduleRequires B means module B should be completed before A.</rdfs:comment>
        <rdfs:domain rdf:resource="#CurriculumModule"/>
        <rdfs:range rdf:resource="#CurriculumModule"/>
    </owl:ObjectProperty>

    <!-- ============================================================ -->
    <!-- Data Properties                                               -->
    <!-- ============================================================ -->

    <owl:DatatypeProperty rdf:about="#hasDifficulty">
        <rdfs:label>has difficulty</rdfs:label>
        <rdfs:domain rdf:resource="#KnowledgeArticle"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#estimatedMinutes">
        <rdfs:label>estimated minutes</rdfs:label>
        <rdfs:domain rdf:resource="#KnowledgeArticle"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#wordCount">
        <rdfs:label>word count</rdfs:label>
        <rdfs:domain rdf:resource="#KnowledgeArticle"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <!-- ============================================================ -->
    <!-- Difficulty individuals                                        -->
    <!-- ============================================================ -->

    <owl:NamedIndividual rdf:about="#Beginner">
        <rdf:type rdf:resource="#Difficulty"/>
        <rdfs:label>Beginner</rdfs:label>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Intermediate">
        <rdf:type rdf:resource="#Difficulty"/>
        <rdfs:label>Intermediate</rdfs:label>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Advanced">
        <rdf:type rdf:resource="#Difficulty"/>
        <rdfs:label>Advanced</rdfs:label>
    </owl:NamedIndividual>

    <!-- ============================================================ -->
    <!-- Curriculum Module individuals                                 -->
    <!-- ============================================================ -->

    <owl:NamedIndividual rdf:about="#ModuleFoundation">
        <rdf:type rdf:resource="#CurriculumModule"/>
        <rdfs:label>The Foundation</rdfs:label>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#ModuleReactivity">
        <rdf:type rdf:resource="#CurriculumModule"/>
        <rdfs:label>Why SolidJS?</rdfs:label>
        <kb:moduleRequires rdf:resource="#ModuleFoundation"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#ModuleLearningSystem">
        <rdf:type rdf:resource="#CurriculumModule"/>
        <rdfs:label>Learning System Reliability</rdfs:label>
        <kb:moduleRequires rdf:resource="#ModuleFoundation"/>
    </owl:NamedIndividual>

    <!-- ============================================================ -->
    <!-- Sample article individuals                                    -->
    <!-- ============================================================ -->

    <owl:NamedIndividual rdf:about="#FineGrainedReactivity">
        <rdf:type rdf:resource="#Concept"/>
        <rdfs:label>Fine-Grained Reactivity</rdfs:label>
        <kb:hasDifficulty>intermediate</kb:hasDifficulty>
        <kb:estimatedMinutes rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">20</kb:estimatedMinutes>
        <kb:belongsToModule rdf:resource="#ModuleReactivity"/>
        <kb:relatedTo rdf:resource="#ObserverPattern"/>
        <kb:relatedTo rdf:resource="#JavaScriptProxies"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#ObserverPattern">
        <rdf:type rdf:resource="#Concept"/>
        <rdfs:label>Observer Pattern</rdfs:label>
        <kb:hasDifficulty>intermediate</kb:hasDifficulty>
        <kb:estimatedMinutes rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">18</kb:estimatedMinutes>
        <kb:belongsToModule rdf:resource="#ModuleReactivity"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#JavaScriptProxies">
        <rdf:type rdf:resource="#Concept"/>
        <rdfs:label>JavaScript Proxies</rdfs:label>
        <kb:hasDifficulty>intermediate</kb:hasDifficulty>
        <kb:estimatedMinutes rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">16</kb:estimatedMinutes>
        <kb:belongsToModule rdf:resource="#ModuleReactivity"/>
        <kb:hasPrerequisite rdf:resource="#FineGrainedReactivity"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#GraphValidation">
        <rdf:type rdf:resource="#CSFundamentals"/>
        <rdfs:label>Graph Validation</rdfs:label>
        <kb:hasDifficulty>intermediate</kb:hasDifficulty>
        <kb:estimatedMinutes rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">16</kb:estimatedMinutes>
        <kb:belongsToModule rdf:resource="#ModuleLearningSystem"/>
        <kb:relatedTo rdf:resource="#ExecutableQualityGates"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#ExecutableQualityGates">
        <rdf:type rdf:resource="#Concept"/>
        <rdfs:label>Executable Quality Gates</rdfs:label>
        <kb:hasDifficulty>intermediate</kb:hasDifficulty>
        <kb:estimatedMinutes rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">14</kb:estimatedMinutes>
        <kb:belongsToModule rdf:resource="#ModuleLearningSystem"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#SolidJS">
        <rdf:type rdf:resource="#Technology"/>
        <rdfs:label>SolidJS</rdfs:label>
        <kb:hasDifficulty>intermediate</kb:hasDifficulty>
        <kb:estimatedMinutes rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">15</kb:estimatedMinutes>
        <kb:belongsToModule rdf:resource="#ModuleReactivity"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#BreakReactivityLab">
        <rdf:type rdf:resource="#Lab"/>
        <rdfs:label>Lab: Break Reactivity in 5 Ways</rdfs:label>
        <kb:hasDifficulty>intermediate</kb:hasDifficulty>
        <kb:estimatedMinutes rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">45</kb:estimatedMinutes>
        <kb:belongsToModule rdf:resource="#ModuleReactivity"/>
        <kb:hasPrerequisite rdf:resource="#FineGrainedReactivity"/>
        <kb:hasPrerequisite rdf:resource="#SolidJS"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#RepairGraphLab">
        <rdf:type rdf:resource="#Lab"/>
        <rdfs:label>Lab: Repair a Knowledge Graph</rdfs:label>
        <kb:hasDifficulty>intermediate</kb:hasDifficulty>
        <kb:estimatedMinutes rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">45</kb:estimatedMinutes>
        <kb:belongsToModule rdf:resource="#ModuleLearningSystem"/>
        <kb:hasPrerequisite rdf:resource="#GraphValidation"/>
        <kb:hasPrerequisite rdf:resource="#ExecutableQualityGates"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#IslandsArchitecture">
        <rdf:type rdf:resource="#Concept"/>
        <rdfs:label>Islands Architecture</rdfs:label>
        <kb:hasDifficulty>intermediate</kb:hasDifficulty>
        <kb:estimatedMinutes rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">18</kb:estimatedMinutes>
        <kb:belongsToModule rdf:resource="#ModuleFoundation"/>
        <kb:relatedTo rdf:resource="#SolidJS"/>
    </owl:NamedIndividual>

</rdf:RDF>
