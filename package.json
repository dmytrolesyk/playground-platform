{
  "name": "retro-cv",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node --experimental-strip-types scripts/build-knowledge-graph.ts",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "astro check",
    "check": "biome check . && astro check",
    "test": "vitest run --passWithNoTests --exclude 'tests/e2e/**'",
    "verify:knowledge": "node --experimental-strip-types scripts/audit-knowledge.ts",
    "check:links": "node --experimental-strip-types scripts/check-external-links.ts",
    "verify": "pnpm prebuild && biome check . && astro check && vitest run --passWithNoTests --exclude 'tests/e2e/**' && pnpm verify:knowledge",
    "generate-cv": "node --experimental-strip-types scripts/generate-cv.ts",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:update": "playwright test --config tests/e2e/playwright.config.ts --update-snapshots all"
  },
  "dependencies": {
    "98.css": "^0.1.21",
    "@astrojs/node": "^10.0.5",
    "@astrojs/solid-js": "^6.0.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "astro": "^6.1.8",
    "mermaid": "^11.14.0",
    "resend": "^6.12.0",
    "solid-js": "^1.9.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@playground/knowledge-engine": "workspace:*",
    "@astrojs/check": "^0.9.8",
    "@biomejs/biome": "^2.4.12",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "vitest": "^4.1.4",
    "yaml": "^2.8.3"
  }
}
