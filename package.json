{
  "name": "retro-cv",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "astro check",
    "check": "biome check . && astro check",
    "test": "vitest run --passWithNoTests",
    "verify": "biome check . && astro check && vitest run --passWithNoTests"
  },
  "dependencies": {
    "98.css": "^0.1.21",
    "@astrojs/node": "^10.0.5",
    "@astrojs/solid-js": "^6.0.1",
    "astro": "^6.1.8",
    "solid-js": "^1.9.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@biomejs/biome": "^2.4.12",
    "vitest": "^4.1.4"
  }
}
